# OKClip backend environment
# Copy to .env and fill in.

# HTTP
PORT=3001
NODE_ENV=development

# Deepgram — transcription + word-level timestamps + speaker diarization
DEEPGRAM_API_KEY=

# Bypassing YouTube's datacenter-IP bot check (use ONE of these on a server):
# 1. A residential proxy (recommended — robust, no expiry):
YTDLP_PROXY=
# 2. A Netscape cookies.txt (works but the session expires within days):
YTDLP_COOKIES=


# Sumopod — OpenAI-compatible LLM for moment selection, scoring, captions
SUMOPOD_API_KEY=
SUMOPOD_BASE_URL=https://ai.sumopod.com/v1
SUMOPOD_MODEL=deepseek-v4-flash

# Storage
STORAGE_DIR=/tmp/okclip
CLIP_TTL_MS=86400000

# Style memory (persistent, not tmp)
PREFERENCES_DIR=data/preferences

# Product limits
MAX_SOURCE_SECONDS=7200
